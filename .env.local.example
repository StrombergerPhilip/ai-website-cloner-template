# Anthropic Claude API — required for Chat-Drawer + Cashback-Erklärung
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: override the default model (default = claude-opus-4-7)
# ANTHROPIC_MODEL=claude-opus-4-7

# Resend — required for the Kontakt-Formular to actually send mail.
# If unset, the server action falls back to console-logging the submission.
RESEND_API_KEY=re_xxx

# From-address must be a domain you've verified in Resend.
# `onboarding@resend.dev` works out of the box for dev/testing.
RESEND_FROM_EMAIL="Foxora <onboarding@resend.dev>"

# Where Kontakt-Anfragen land.
RESEND_TO_EMAIL=hello@foxora.io
